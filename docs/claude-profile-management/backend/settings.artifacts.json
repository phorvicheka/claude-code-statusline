{
  "enabledPlugins": {
    "code-review@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": false,
    "developer-tools@my-custom-skills": false,
    "code-simplifier@claude-plugins-official": false,
    "codex@openai-codex": false,
    "claude-code-setup@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/safe-bash-auto-approve.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/safe-edit-auto-approve.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/safe-edit-auto-approve.sh"
          }
        ]
      }
    ]
  }
}
